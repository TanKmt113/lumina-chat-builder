{
  "entities": {
    "Chatbot": {
      "title": "Chatbot",
      "description": "A customized chatbot configuration.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the chatbot project." },
        "userId": { "type": "string", "description": "The owner's user ID." },
        "botName": { "type": "string", "description": "The name displayed to end users." },
        "primaryColor": { "type": "string", "description": "The primary theme color (hex)." },
        "welcomeMessage": { "type": "string", "description": "The first message the bot sends." },
        "systemPrompt": { "type": "string", "description": "The system instruction for the AI model." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "userId", "botName", "primaryColor"]
    }
  },
  "firestore": {
    "/chatbots/{chatbotId}": {
      "schema": "Chatbot",
      "description": "Chatbot configurations."
    }
  }
}
